PORT=4000
JWT_SECRET=change-me-to-a-long-random-string

# LLM: openai | anthropic (если не указано — берётся OpenAI при наличии OPENAI_API_KEY, иначе Anthropic)
AI_PROVIDER=openai
OPENAI_API_KEY=sk-...
# Одна модель на все роли или отдельно:
# OPENAI_MODEL=gpt-4o
# OPENAI_MODEL_GENERATOR=gpt-4o
# OPENAI_MODEL_CRITIC=gpt-4o-mini
# OPENAI_MODEL_EDITOR=gpt-4o

ANTHROPIC_API_KEY=sk-ant-api03-...
# ANTHROPIC_MODEL_GENERATOR=claude-sonnet-4-5
# ANTHROPIC_MODEL_CRITIC=claude-haiku-4-5
# ANTHROPIC_MODEL_EDITOR=claude-sonnet-4-5
CORS_ORIGIN=http://localhost:5173
# Пока без страницы входа: API принимает запросы от имени пользователя dev@local
SKIP_AUTH=true
